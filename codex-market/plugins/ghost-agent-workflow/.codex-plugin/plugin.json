    ],
    "defaultPrompt": [
      "\u6211\u5df2\u7ecf\u5b8c\u6210\u5f53\u524d\u4efb\u52a1\u8bf4\u660e\u3002\u4f7f\u7528 $parallel-task-planner \u5bf9\u5f53\u524d\u4efb\u52a1\u8fdb\u884c DAG \u6216\u5e76\u884c\u89c4\u5212\u3002\u6267\u884c\u65b9\u5f0f\uff1a<\u5b50\u7ebf\u7a0b\u6216\u5b50\u4ee3\u7406\uff0c\u5fc5\u987b\u4e8c\u9009\u4e00>\uff1b\u8bf7\u6c42\u8303\u56f4\uff1a<\u53ea\u89c4\u5212\u6216\u89c4\u5212\u540e\u6267\u884c\uff0c\u5fc5\u987b\u4e8c\u9009\u4e00>\u3002\u4e0d\u8981\u63a8\u65ad\u6216\u9ed8\u8ba4\u4efb\u4f55\u9009\u9879\u3002",
      "\u4f7f\u7528 $git-commit \u521b\u5efa\u672c\u5730\u6267\u884c\u7ebf\u7a0b\uff0c\u5b8c\u6210\u4e00\u6b21\u542f\u52a8\u5065\u5eb7\u68c0\u67e5\u548c\u6a21\u578b\u56de\u9000\u540e\u63d0\u4ea4\u5f53\u524d\u6539\u52a8\u3002"
    ]
